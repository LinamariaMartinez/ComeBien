# ─────────────────────────────────────────────────────────────────────────────
# ComeBien — variables de entorno
# Copia este archivo como .env.local y rellena cada valor.
# NUNCA subas .env.local a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — supabase.com → tu proyecto → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase — misma página → "anon / public" key
# Esta clave es segura para exponer en el navegador (solo acceso público).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — platform.openai.com → API keys → "Create new secret key"
# Necesitas acceso a gpt-4o-mini (tier 1+).
OPENAI_API_KEY=
